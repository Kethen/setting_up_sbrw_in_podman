Subject: [PATCH 2/2] revert group member lookup to base openfire rest api

---
 .../soapboxrace/core/xmpp/openfire/OpenfireXmppProvider.java | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/src/main/java/com/soapboxrace/core/xmpp/openfire/OpenfireXmppProvider.java b/src/main/java/com/soapboxrace/core/xmpp/openfire/OpenfireXmppProvider.java
index 386b7f00..e76bbf6b 100644
--- a/src/main/java/com/soapboxrace/core/xmpp/openfire/OpenfireXmppProvider.java
+++ b/src/main/java/com/soapboxrace/core/xmpp/openfire/OpenfireXmppProvider.java
@@ -178,7 +178,10 @@ public class OpenfireXmppProvider implements XmppProvider {
                     String roomName = entity.getRoomName();
                     
                     if (roomName.contains("group.channel.")) {
-                        return getAllOccupantsInRoom(roomName);
+                        List<Long> occupants = getAllOccupantsInRoom(roomName);
+                        if (occupants.contains(personaId)){
+                            return occupants;
+                        }
                     }
                 }
             }
