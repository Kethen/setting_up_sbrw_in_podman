 project-defaults.yml | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/project-defaults.yml b/project-defaults.yml
index 9b377250..ea4c3854 100644
--- a/project-defaults.yml
+++ b/project-defaults.yml
@@ -5,7 +5,7 @@ thorntail:
         driver-name: mysql
         connection-url: jdbc:mysql://localhost:3306/SOAPBOX
         user-name: soapbox
-        password: secret
+        password: SOAPBOX-SQL-PASSWORD
         valid-connection-checker-class-name: org.jboss.jca.adapters.jdbc.extensions.mysql.MySQLValidConnectionChecker
         validate-on-match: true
         background-validation: false
@@ -37,4 +37,4 @@ thorntail:
             filter-refs:
               gzipFilter:
                 priority: 1
-                predicate: "exists['%{o,Content-Type}'] and regex[pattern='(?:application/javascript|text/css|text/html|text/xml|application/json|application/xml)(;.*)?', value=%{o,Content-Type}, full-match=true]"
\ No newline at end of file
